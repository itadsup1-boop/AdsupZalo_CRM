generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                  String               @id @default(uuid())
  name                String               @unique
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  activityLogs        ActivityLog[]
  aiConfig            AiConfig?
  aiSuggestions       AiSuggestion[]
  settings            AppSetting[]
  appointments        Appointment[]
  automationRules     AutomationRule[]
  contacts            Contact[]
  conversations       Conversation[]
  dailyStats          DailyMessageStat[]
  duplicateGroups     DuplicateGroup[]
  groupPolls          GroupPoll[]
  integrations        Integration[]
  messageReactions    MessageReaction[]
  messageTemplates    MessageTemplate[]
  messages            Message[]
  pinnedConversations PinnedConversation[]
  savedReports        SavedReport[]
  syncLogs            SyncLog[]
  teams               Team[]
  users               User[]
  zaloAccountAccess   ZaloAccountAccess[]
  zaloAccounts        ZaloAccount[]

  @@map("organizations")
}

model Team {
  id        String       @id @default(uuid())
  orgId     String       @map("org_id")
  name      String
  createdAt DateTime     @default(now()) @map("created_at")
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users     User[]

  @@unique([orgId, id])
  @@map("teams")
}

model User {
  id               String              @id @default(uuid())
  orgId            String              @map("org_id")
  teamId           String?             @map("team_id")
  email            String
  passwordHash     String              @map("password_hash")
  fullName         String              @map("full_name")
  role             String              @default("member")
  isActive         Boolean             @default(true) @map("is_active")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  isPending        Boolean             @default(false) @map("is_pending")
  activityLogs     ActivityLog[]
  appointments     Appointment[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  messageTemplates MessageTemplate[]
  repliedMessages  Message[]           @relation("RepliedMessages")
  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [orgId, teamId], references: [orgId, id])
  zaloAccess       ZaloAccountAccess[]
  zaloAccounts     ZaloAccount[]
  pushSubscriptions PushSubscription[]

  @@unique([orgId, email])
  @@unique([orgId, id])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  keys      Json     // p256dh, auth
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model ZaloAccount {
  id              String              @id @default(uuid())
  orgId           String              @map("org_id")
  ownerUserId     String              @map("owner_user_id")
  zaloUid         String?             @map("zalo_uid")
  displayName     String?             @map("display_name")
  avatarUrl       String?             @map("avatar_url")
  phone           String?
  status          String              @default("disconnected")
  sessionData     Json?               @map("session_data")
  lastConnectedAt DateTime?           @map("last_connected_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  conversations   Conversation[]
  dailyStats      DailyMessageStat[]
  access          ZaloAccountAccess[]
  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner           User                @relation(fields: [orgId, ownerUserId], references: [orgId, id])

  @@unique([orgId, zaloUid])
  @@unique([orgId, id])
  @@map("zalo_accounts")
}

model ZaloAccountAccess {
  id            String       @id @default(uuid())
  zaloAccountId String       @map("zalo_account_id")
  userId        String       @map("user_id")
  permission    String       @default("read")
  createdAt     DateTime     @default(now()) @map("created_at")
  orgId         String       @map("org_id")
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [orgId, userId], references: [orgId, id], onDelete: Cascade)
  zaloAccount   ZaloAccount  @relation(fields: [orgId, zaloAccountId], references: [orgId, id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

model Contact {
  id                String         @id @default(uuid())
  orgId             String         @map("org_id")
  zaloUid           String?        @map("zalo_uid")
  phone             String?
  email             String?        @map("email")
  fullName          String?        @map("full_name")
  crmName           String?        @map("crm_name")
  avatarUrl         String?        @map("avatar_url")
  source            String?
  sourceDate        DateTime?      @map("source_date")
  firstContactDate  DateTime?      @map("first_contact_date")
  status            String?        @default("new")
  nextAppointment   DateTime?      @map("next_appointment")
  assignedUserId    String?        @map("assigned_user_id")
  notes             String?
  tags              Json           @default("[]")
  metadata          Json           @default("{}")
  leadScore         Int            @default(0) @map("lead_score")
  lastActivity      DateTime?      @map("last_activity")
  mergedInto        String?        @map("merged_into")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  appointments      Appointment[]
  assignedUser      User?          @relation("AssignedContacts", fields: [orgId, assignedUserId], references: [orgId, id])
  organizations     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mergedIntoContact Contact?       @relation("ContactMerge", fields: [orgId, mergedInto], references: [orgId, id])
  mergedFrom        Contact[]      @relation("ContactMerge")
  conversations     Conversation[]

  @@unique([orgId, id])
  @@index([orgId, phone])
  @@index([orgId, zaloUid])
  @@index([orgId, mergedInto])
  @@map("contacts")
}

model Conversation {
  id               String               @id @default(uuid())
  orgId            String               @map("org_id")
  zaloAccountId    String               @map("zalo_account_id")
  contactId        String?              @map("contact_id")
  threadType       String               @default("user")
  externalThreadId String?              @map("external_thread_id")
  lastMessageAt    DateTime?            @map("last_message_at")
  unreadCount      Int                  @default(0) @map("unread_count")
  isReplied        Boolean              @default(true) @map("is_replied")
  tab              String               @default("main") @map("tab")
  createdAt        DateTime             @default(now()) @map("created_at")
  aiSuggestions    AiSuggestion[]
  contact          Contact?             @relation(fields: [orgId, contactId], references: [orgId, id])
  org              Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount      ZaloAccount          @relation(fields: [orgId, zaloAccountId], references: [orgId, id], onDelete: Cascade)
  messages         Message[]
  pins             PinnedConversation[]

  @@unique([zaloAccountId, externalThreadId])
  @@unique([orgId, id])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String            @id @default(uuid())
  conversationId  String            @map("conversation_id")
  zaloMsgId       String?           @map("zalo_msg_id")
  senderType      String            @map("sender_type")
  senderUid       String?           @map("sender_uid")
  senderName      String?           @map("sender_name")
  content         String?
  contentType     String            @default("text") @map("content_type")
  attachments     Json              @default("[]")
  quote           Json?             @map("quote")
  albumKey        String?           @map("album_key")
  albumIndex      Int?              @map("album_index")
  albumTotal      Int?              @map("album_total")
  isDeleted       Boolean           @default(false) @map("is_deleted")
  deletedAt       DateTime?         @map("deleted_at")
  sentAt          DateTime          @map("sent_at")
  repliedByUserId String?           @map("replied_by_user_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  orgId               String            @map("org_id")
  messageFingerprint  String?           @map("message_fingerprint")
  reactions       MessageReaction[]
  conversation    Conversation      @relation(fields: [orgId, conversationId], references: [orgId, id], onDelete: Cascade)
  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repliedBy       User?             @relation("RepliedMessages", fields: [orgId, repliedByUserId], references: [orgId, id])

  @@unique([conversationId, zaloMsgId])
  @@unique([orgId, id])
  @@index([conversationId, albumKey])
  @@map("messages")
}

model Appointment {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  contactId       String       @map("contact_id")
  assignedUserId  String?      @map("assigned_user_id")
  appointmentDate DateTime     @map("appointment_date")
  appointmentTime String?      @map("appointment_time")
  type            String?
  status          String       @default("scheduled")
  notes           String?
  reminderSent    Boolean      @default(false) @map("reminder_sent")
  createdAt       DateTime     @default(now()) @map("created_at")
  assignedUser    User?        @relation(fields: [orgId, assignedUserId], references: [orgId, id])
  contact         Contact      @relation(fields: [orgId, contactId], references: [orgId, id], onDelete: Cascade)
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, id])
  @@map("appointments")
}

model ActivityLog {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  userId     String?      @map("user_id")
  action     String
  entityType String?      @map("entity_type")
  entityId   String?      @map("entity_id")
  details    Json         @default("{}")
  createdAt  DateTime     @default(now()) @map("created_at")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model DailyMessageStat {
  id                String       @id @default(uuid())
  orgId             String       @map("org_id")
  userId            String       @map("user_id")
  zaloAccountId     String       @map("zalo_account_id")
  statDate          DateTime     @map("stat_date") @db.Date
  messagesSent      Int          @default(0) @map("messages_sent")
  messagesReceived  Int          @default(0) @map("messages_received")
  messagesUnread    Int          @default(0) @map("messages_unread")
  messagesUnreplied Int          @default(0) @map("messages_unreplied")
  avgResponseTime   Int?         @map("avg_response_time_seconds")
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount       ZaloAccount  @relation(fields: [orgId, zaloAccountId], references: [orgId, id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

model Integration {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  type       String
  name       String       @default("")
  config     Json         @default("{}")
  enabled    Boolean      @default(true)
  lastSyncAt DateTime?    @map("last_sync_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs   SyncLog[]

  @@unique([orgId, id])
  @@map("integrations")
}

model SyncLog {
  id            String       @id @default(uuid())
  integrationId String       @map("integration_id")
  direction     String
  recordCount   Int          @default(0) @map("record_count")
  status        String
  errorMessage  String?      @map("error_message")
  createdAt     DateTime     @default(now()) @map("created_at")
  orgId         String       @map("org_id")
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integration   Integration  @relation(fields: [orgId, integrationId], references: [orgId, id], onDelete: Cascade)

  @@map("sync_logs")
}

model AppSetting {
  id             String       @id @default(uuid())
  orgId          String       @map("org_id")
  settingKey     String       @map("setting_key")
  valuePlain     String?      @map("value_plain")
  valueEncrypted Bytes?       @map("value_encrypted")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

model DuplicateGroup {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  contactIds String[]     @map("contact_ids")
  matchType  String       @map("match_type")
  confidence Float        @default(1.0)
  resolved   Boolean      @default(false)
  createdAt  DateTime     @default(now()) @map("created_at")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, resolved])
  @@map("duplicate_groups")
}

model SavedReport {
  id        String       @id @default(uuid())
  orgId     String       @map("org_id")
  name      String
  type      String
  config    Json         @default("{}")
  createdBy String       @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("saved_reports")
}

model AutomationRule {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  name        String
  description String?
  trigger     String
  conditions  Json         @default("[]")
  actions     Json         @default("[]")
  enabled     Boolean      @default(true)
  priority    Int          @default(0)
  runCount    Int          @default(0) @map("run_count")
  lastRunAt   DateTime?    @map("last_run_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, trigger, enabled, priority])
  @@map("automation_rules")
}

model MessageTemplate {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  ownerUserId String?      @map("owner_user_id")
  name        String
  content     String
  category    String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner       User?        @relation(fields: [orgId, ownerUserId], references: [orgId, id])

  @@unique([orgId, id])
  @@index([orgId, ownerUserId])
  @@index([orgId, category])
  @@map("message_templates")
}

model AiConfig {
  id        String       @id @default(uuid())
  orgId     String       @unique @map("org_id")
  provider  String       @default("anthropic")
  model     String       @default("claude-sonnet-4-6")
  maxDaily  Int          @default(500) @map("max_daily")
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiSuggestion {
  id             String       @id @default(uuid())
  orgId          String       @map("org_id")
  conversationId String       @map("conversation_id")
  messageId      String?      @map("message_id")
  type           String
  content        String
  confidence     Float
  accepted       Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [orgId, conversationId], references: [orgId, id], onDelete: Cascade)
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([conversationId, createdAt])
  @@index([orgId, type, createdAt])
  @@map("ai_suggestions")
}

model MessageReaction {
  id        String       @id @default(uuid())
  messageId String       @map("message_id")
  reactorId String       @map("reactor_id")
  emoji     String
  createdAt DateTime     @default(now()) @map("created_at")
  orgId     String       @map("org_id")
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  message   Message      @relation(fields: [orgId, messageId], references: [orgId, id], onDelete: Cascade)

  @@unique([messageId, reactorId])
  @@map("message_reactions")
}

model PinnedConversation {
  id             String       @id @default(uuid())
  orgId          String       @map("org_id")
  zaloAccountId  String       @map("zalo_account_id")
  conversationId String       @map("conversation_id")
  pinnedAt       DateTime     @default(now()) @map("pinned_at")
  conversation   Conversation @relation(fields: [orgId, conversationId], references: [orgId, id], onDelete: Cascade)
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, conversationId])
  @@map("pinned_conversations")
}

model GroupPoll {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  zaloAccountId   String       @map("zalo_account_id")
  groupExternalId String       @map("group_external_id")
  zaloPollId      String       @map("zalo_poll_id")
  question        String
  options         Json         @default("[]")
  isMultiChoice   Boolean      @default(false) @map("is_multi_choice")
  isAnonymous     Boolean      @default(false) @map("is_anonymous")
  isLocked        Boolean      @default(false) @map("is_locked")
  expiresAt       DateTime?    @map("expires_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, zaloPollId])
  @@index([orgId, groupExternalId])
  @@map("group_polls")
}
