{
  "manifest_version": 3,
  "name": "Zalo CRM Sync",
  "version": "1.0.0",
  "description": "Tự động đồng bộ tin nhắn Zalo Web vào CRM",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.zalo.me/*",
    "https://crm.adsup.vn/*",
    "http://localhost:3000/*",
    "http://localhost:*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://chat.zalo.me/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zalo CRM Sync",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
